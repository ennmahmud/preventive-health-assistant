# Preventive Health Assistant — Environment Variables
# Copy to .env and fill in your values before starting the server.
#
#   cp .env.example .env
#   # then edit .env

# ── Auth ──────────────────────────────────────────────────────────────────────
# Bearer token required on all /api/v1/ endpoints.
# Generate a strong random value:  python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your-api-key-here

# JWT signing secret (used for user session tokens).
# Must be at least 32 characters.
ELAN_SECRET_KEY=your-jwt-secret-at-least-32-chars-here

# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Enables intelligent explanations and personalised chat responses.
# Without this key the app falls back to template-based responses.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Server ────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
# Postgres + pgvector connection. The default targets the docker-compose
# `db` sidecar. For local-only runs without docker, leave it unset and the
# app falls back to a SQLite file at data/elan.db.
DATABASE_URL=postgresql+psycopg://elan:elan_dev_pw@db:5432/elan

# Credentials for the docker-compose Postgres sidecar
POSTGRES_USER=elan
POSTGRES_PASSWORD=elan_dev_pw
POSTGRES_DB=elan
